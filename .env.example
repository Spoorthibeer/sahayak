# Copy this file to .env and fill in your real keys.
# Never commit the real .env file — it's already in .gitignore.

GEMINI_API_KEY=your_gemini_api_key_here

# Sarvam AI key for /transcribe and /speak (Speech-to-Text and
# Text-to-Speech) — purpose-built for Indian languages, free credits, no
# card required. Get one at https://dashboard.sarvam.ai.
SARVAM_API_KEY=your_sarvam_api_key_here

# GOOGLE_APPLICATION_CREDENTIALS is no longer read by any active code path
# (voice moved to Sarvam AI above) — removed from here deliberately. The
# google-credentials.json file and its .gitignore protection are left in
# place on disk as an untested fallback until the Sarvam swap is confirmed
# working in a real browser; do not delete either yet.
