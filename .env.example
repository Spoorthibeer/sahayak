# Copy this file to .env and fill in your real keys.
# Never commit the real .env file — it's already in .gitignore.

GEMINI_API_KEY=your_gemini_api_key_here

# Path to a Google Cloud service account JSON key with the Speech-to-Text
# and Text-to-Speech APIs enabled (project: sahayak-hackathon). Used by
# app.py's /transcribe and /speak endpoints. The file itself must NEVER be
# committed — .gitignore's *credentials*.json pattern already excludes it,
# but double-check before committing if you ever rename it.
GOOGLE_APPLICATION_CREDENTIALS=google-credentials.json
